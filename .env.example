# ─── MySQL ────────────────────────────────────────────────────────────────────
# Credentials for the MySQL database service (used by docker-compose).
# Change all values before deploying to any non-local environment.
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=dmuster
MYSQL_USER=dmuster
MYSQL_PASSWORD=change_me

# ─── Prisma ───────────────────────────────────────────────────────────────────
# Database connection string consumed by Prisma ORM.
# Must match the MySQL credentials above.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# For local Docker Compose use "db" as host (name of the db service).
DATABASE_URL="mysql://dmuster:change_me@db:3306/dmuster"

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Secret used to sign and verify session tokens. Must be a long random string.
# Generate with:  npx auth secret
#            or:  openssl rand -base64 32
AUTH_SECRET=change_me_secret
# Canonical base URL of the application. Required in production.
# In development Auth.js infers it automatically; can be left as-is.
AUTH_URL=http://localhost:3000

# ─── Application ──────────────────────────────────────────────────────────────
# Default locale for new users and unauthenticated pages.
# Accepted values: "es" (Spanish) | "en" (English)
DEFAULT_LOCALE=es
