// DMuster Prisma schema.
// Datasource URL is provided by prisma.config.ts (Prisma 7 config-driven setup).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum CampaignRole {
  DM
  PLAYER
}

enum Locale {
  es
  en
}

enum AvailabilityStatus {
  YES
  NO
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  locale        Locale    @default(es)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  createdCampaigns Campaign[]       @relation("CampaignCreatedBy")
  campaigns        CampaignPlayer[]
  createdHolidays  Holiday[]        @relation("HolidayCreatedBy")
  availabilities   Availability[]

  @@map("users")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  // Two-letter chip label shown in the calendar UI (e.g. "AC", "OR").
  // Not @unique on purpose: the model is designed for future multi-group
  // support (CLAUDE.md §4), where tags are only unique within a group.
  tag         String   @db.VarChar(2)
  description String?  @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User             @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  players   CampaignPlayer[]

  @@map("campaigns")
}

model CampaignPlayer {
  campaignId String
  userId     String
  role       CampaignRole @default(PLAYER)
  createdAt  DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@map("campaign_players")
}

// Weekday dates that are eligible for play in addition to weekends.
// Weekends (Sat/Sun) are always eligible and are not stored here.
model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("HolidayCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@map("holidays")
}

// A player's global availability for a single calendar day. The response is
// not scoped to a campaign: it applies to every campaign the player belongs
// to. Only YES/NO is ever stored — the "MAYBE"/pending state is derived from
// the absence of a row for a (date, user) pair, never persisted.
model Availability {
  id        String             @id @default(cuid())
  date      DateTime           @db.Date
  userId    String
  status    AvailabilityStatus
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([date, userId])
  @@map("availabilities")
}

// ─── Auth.js v5 adapter tables ───────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}
